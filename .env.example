# /etc/time-tracker/.env
# Copy this file to /etc/time-tracker/.env and fill in the values.
# Lines beginning with # are comments.
#
# After editing, reload the daemon:
#   sudo launchctl kickstart -k system/com.timetracker.daemon

# ── Required ──────────────────────────────────────────────────────────────────

# Full URL of the attendance API endpoint.  The tracker POSTs JSON here.
# See docs/api.md for the expected request/response schema.
SYNC_API_URL=https://your-api-endpoint.example.com/attendance

# ── Authentication ────────────────────────────────────────────────────────────

# Bearer token sent in the Authorization header.  Leave empty if the API
# does not require authentication (not recommended for production).
SYNC_API_KEY=

# ── Machine identity ──────────────────────────────────────────────────────────

# The machine ID is read automatically from the hardware serial number
# (IOPlatformSerialNumber via IOKit) and cannot be overridden by the user.
# It is the same serial number shown in "About This Mac".

# ── Sync schedule ─────────────────────────────────────────────────────────────

# Morning sync fires the first time the system becomes active on a given day
# and the local hour is >= MORNING_SYNC_HOUR.  It pushes all sessions from
# previous days that have not yet been uploaded.
MORNING_SYNC_HOUR=6

# Evening sync fires once per day at EVENING_SYNC_HOUR:EVENING_SYNC_MINUTE
# (local time) and pushes today's sessions.
EVENING_SYNC_HOUR=18
EVENING_SYNC_MINUTE=30

# ── Activity detection ────────────────────────────────────────────────────────

# How many consecutive minutes without keyboard/mouse input before the session
# is classified as "idle" rather than "active".
IDLE_THRESHOLD_MINUTES=5

# How often (in seconds) the monitor samples the HID idle counter.
# Lower = finer granularity but more CPU wake-ups.  30 s is a good balance.
POLL_INTERVAL_SECONDS=30

# ── Storage ───────────────────────────────────────────────────────────────────

# Absolute path to the SQLite database file.
DB_PATH=/var/lib/time-tracker/tracker.db

# Directory where log files are written (used by code, supplementing the
# paths already set in the launchd plist).
LOG_PATH=/var/log/time-tracker

# Number of days to retain local records after a successful sync.
# Records older than this are deleted regardless of sync status (safety net).
RETENTION_DAYS=3

# ── Network ───────────────────────────────────────────────────────────────────

# HTTP client timeout (seconds) for each sync request.
SYNC_TIMEOUT_SECONDS=30
