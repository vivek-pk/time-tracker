<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  entitlements/location-helper.plist
  ===================================
  Used when codesigning the location-helper binary so macOS allows it to call
  CoreLocation APIs.  Applied during `make install` via codesign.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.personal-information.location</key>
    <true/>
</dict>
</plist>
